# ── Minecraft ────────────────────────────────────────────────────
# Version du serveur (ex: 1.21.4)
MC_VERSION=1.21.4

# Type de serveur : VANILLA, PAPER, FORGE, FABRIC...
MC_TYPE=VANILLA

# RAM allouée (ex: 4G, 8G)
RAM=4G

# Nom affiché dans la liste des serveurs
MOTD=Mon Serveur Minecraft

# Mode de jeu : survival, creative, adventure
GAMEMODE=survival

# Difficulté : peaceful, easy, normal, hard
DIFFICULTY=normal

# Nombre max de joueurs
MAX_PLAYERS=10

# Port réseau
PORT=25565

# ── Sécurité ──────────────────────────────────────────────────────
# Mot de passe RCON (génère un mot de passe aléatoire)
RCON_PASSWORD=changeme

# ── GitHub ────────────────────────────────────────────────────────
# Token GitHub avec permissions "repo" et "gist"
# Créer sur : github.com → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=ghp_xxxxx

# ID du Gist pour le statut du serveur
# Créer sur : gist.github.com avec un fichier mc-status.json contenant :
# { "running": false, "hostName": "", "since": "" }
GIST_ID=xxxxx

# URL de ton repo Git (pour l'auto-update et la sauvegarde du monde)
GIT_REPO_URL=https://github.com/username/mon-serveur.git

# ── Playit.gg ─────────────────────────────────────────────────────
# Clé secrète de l'agent Playit.gg (trouvable dans %LOCALAPPDATA%\playit_gg\playit.toml)
PLAYIT_SECRET=xxxxx

# Adresse du tunnel Playit.gg (ex: monserveur.joinmc.link)
PLAYIT_ADDRESS=xxxxx.joinmc.link
